# .env.example — Desenvolvimento local
# Copie este arquivo para .env e ajuste se necessário.
# O .env nunca deve ser commitado no git (já está no .gitignore).

# ── Banco de dados (container postgres local) ────────────────────────────────
POSTGRES_DB=crm_saas
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=crm_pass
POSTGRES_PORT=5432

# ── Backend ──────────────────────────────────────────────────────────────────
# JWT_SECRET: pode ser qualquer string em desenvolvimento.
# Em produção DEVE ser uma string aleatória de 64+ caracteres.
JWT_SECRET=local-dev-secret-not-for-production

ADMIN_EMAIL=master@franqueadora.com
ADMIN_PASSWORD=master123

CORS_ORIGINS=http://localhost:3000
BACKEND_PORT=8001

# ── Frontend ─────────────────────────────────────────────────────────────────
# URL do backend que o navegador vai chamar (build-time ARG no Dockerfile).
REACT_APP_BACKEND_URL=http://localhost:8001
FRONTEND_PORT=3000
