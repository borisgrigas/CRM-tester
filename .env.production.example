# .env.production.example — Produção
# NÃO use este arquivo diretamente. Configure cada variável no painel
# do seu host (Railway, Render, Fly.io…) ou em um .env seguro que
# jamais seja commitado no git.
#
# Todos os valores <ENTRE_COLCHETES> são placeholders obrigatórios.
# Substitua TODOS antes de fazer o primeiro deploy.

# ── Banco de dados ────────────────────────────────────────────────────────────
# No Railway: provisionado automaticamente pelo serviço PostgreSQL.
# A variável DATABASE_URL é injetada no serviço backend de forma automática.
# Se usar outro host, construa a URL no formato abaixo:
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:5432/<DB_NAME>

# ── Segredos da aplicação ─────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
# Nunca reutilize o mesmo secret entre ambientes.
JWT_SECRET=<GERE_COM_openssl_rand_hex_64>

# ── Conta de administrador inicial ───────────────────────────────────────────
# Usado pelo seed.py na primeira inicialização em desenvolvimento.
# Em produção o seed NÃO roda (o Dockerfile usa apenas uvicorn).
# Se precisar criar o primeiro admin manualmente, use o endpoint
# POST /api/auth/register (se habilitado) ou insira direto no banco.
ADMIN_EMAIL=<admin@seudominio.com>
ADMIN_PASSWORD=<SENHA_FORTE_MIN_16_CHARS>

# ── CORS ──────────────────────────────────────────────────────────────────────
# Somente o(s) domínio(s) do seu frontend. Nunca use "*" em produção.
# Múltiplos domínios: separe por vírgula sem espaço.
# Exemplo Railway: https://crm-frontend.up.railway.app
# Exemplo domínio próprio: https://app.seudominio.com
CORS_ORIGINS=https://<SEU_FRONTEND>.up.railway.app

# ── Frontend (build-time ARG) ─────────────────────────────────────────────────
# URL pública do serviço backend. Configurada como Build Variable no Railway
# (não como env var de runtime — o React embute no bundle no momento do build).
# Exemplo Railway: https://crm-backend.up.railway.app
# Exemplo domínio próprio: https://api.seudominio.com
REACT_APP_BACKEND_URL=https://<SEU_BACKEND>.up.railway.app

# ── Integrações (opcionais) ───────────────────────────────────────────────────
# Se for usar webhook de WhatsApp com verificação de assinatura:
# WHATSAPP_VERIFY_TOKEN=<TOKEN_CONFIGURADO_NO_META_FOR_DEVELOPERS>
# WHATSAPP_APP_SECRET=<APP_SECRET_DO_META_FOR_DEVELOPERS>

# ── Observabilidade (opcional) ────────────────────────────────────────────────
# APP_ENV=production
# LOG_LEVEL=info
